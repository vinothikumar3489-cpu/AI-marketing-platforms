# =============================================================================
# Market Genesis AI — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Required  = MUST be set for the app to start / core features to work
# Optional  = feature-specific; omit if you don't need that capability
# Deprecated= documented for reference only (unused in code, will be removed)
# =============================================================================

# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000                          # Required — app listen port
CLIENT_URL=http://localhost:5173   # Required — CORS origin (Vite dev default)
NODE_ENV=development               # Optional — 'development' | 'production' | 'test'

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/marketform_dev
#   Required — Prisma connection string. If NODE_ENV=production, use production DB.

# ── Authentication ───────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_random_64_char_string
#   Required — MUST be at least 32 characters, preferably 64+.
#   Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   WARNING: A weak/numeric secret (e.g. '60021103') will be rejected with a startup warning.

# ── AI Providers ─────────────────────────────────────────────────────────────
# At least ONE of the following is required for AI features.
# The app will try providers in order: Gemini → Groq → OpenAI → OpenRouter → Cerebras → DeepSeek

GROQ_API_KEY=                      # Optional — https://console.groq.com/keys
GROQ_MODEL=llama-3.3-70b-versatile # Optional — defaults to llama-3.3-70b-versatile

GEMINI_API_KEY=                    # Optional — https://aistudio.google.com/apikey
GEMINI_MODEL=gemini-2.0-flash      # Optional — defaults to gemini-2.0-flash

OPENAI_API_KEY=                    # Optional — https://platform.openai.com/api-keys
OPENAI_MODEL=gpt-4o-mini           # Optional — defaults to gpt-4o-mini

OPENROUTER_API_KEY=                # Optional — https://openrouter.ai/keys

CEREBRAS_API_KEY=                  # Optional — https://console.cerebras.ai/
DEEPSEEK_API_KEY=                  # Optional — https://platform.deepseek.com/

# ── Research / Search APIs ───────────────────────────────────────────────────
TAVILY_API_KEY=                    # Required for SEO keyword/competitor/geo intelligence
EXA_API_KEY=                       # Required for SEO competitor & keyword intelligence

# ── Scraping ─────────────────────────────────────────────────────────────────
FIRECRAWL_API_KEY=                 # Required for website scraping (SEO analysis)
JINA_API_KEY=                      # Required for web scraping fallback

# ── Email (Gmail SMTP / Resend) ───────────────────────────────────────────────
# Set EMAIL_PROVIDER=gmail for Gmail SMTP, or EMAIL_PROVIDER=resend for Resend.
# If EMAIL_PROVIDER is unset, defaults to gmail if SMTP_USER and SMTP_PASS are set.
EMAIL_PROVIDER=gmail                # 'gmail' | 'resend' — defaults to gmail if SMTP credentials exist

# Gmail SMTP — requires 2-Step Verification + App Password
SMTP_HOST=smtp.gmail.com           # Default: smtp.gmail.com
SMTP_PORT=587                      # Default: 587
SMTP_USER=                         # Your Gmail address (e.g., you@gmail.com)
SMTP_PASS=                         # Gmail App Password (NOT your normal password)
SMTP_FROM=                         # Optional — defaults to SMTP_USER

# Resend (optional fallback) — https://resend.com
RESEND_API_KEY=                    # Required if EMAIL_PROVIDER=resend
RESEND_FROM_EMAIL=onboarding@resend.dev
#   Required if using Resend — verified sender. Use onboarding@resend.dev for dev.

# ── Image Generation (Pollinations AI + Fal.ai) ───────────────────────────────
# Pollinations AI is the primary provider (free, no API key needed).
# Fal.ai is the fallback (requires FAL_KEY).
IMAGE_PROVIDER=pollinations        # Primary image provider
POLLINATIONS_BASE_URL=https://image.pollinations.ai  # Free — no API key needed
FAL_KEY=                           # Optional — https://fal.ai/dashboard
FAL_IMAGE_MODEL=fal-ai/flux/dev    # Optional — defaults to fal-ai/flux/dev

# ── Video Generation (Shotstack + Creatomate + Cloudinary) ─────────────────────
# Shotstack is the primary provider (free developer account available).
# Creatomate is the first fallback.
# Cloudinary video assembly is the second fallback.
# Storyboard is the final fallback (no API key needed).
VIDEO_PROVIDER=shotstack           # Primary video provider
SHOTSTACK_API_KEY=                 # Optional — https://shotstack.io (free dev account)
SHOTSTACK_STAGE=stage              # Optional — 'stage' (test) or 'live'
CREATOMATE_API_KEY=                # Optional — https://creatomate.com

# ── Asset Storage (Cloudinary) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=             # Required for image/video storage
CLOUDINARY_API_KEY=                # Required for image/video storage
CLOUDINARY_API_SECRET=             # Required for image/video storage

# ── Google PageSpeed ─────────────────────────────────────────────────────────
PAGESPEED_API_KEY=                 # Required for technical SEO audit
#   Also supported: GOOGLE_PAGESPEED_INSIGHTS_API_KEY (fallback env name)
#   Get from: https://developers.google.com/speed/docs/insights/v5/get-started

# ── DataForSEO ───────────────────────────────────────────────────────────────
DATAFORSEO_LOGIN=                  # Required for competitive SEO data
DATAFORSEO_PASSWORD=               # Required for competitive SEO data
#   Get from: https://app.dataforseo.com/api-settings

# ── SEO Integrations ─────────────────────────────────────────────────────────
SEMRUSH_API_KEY=                   # Optional — for Semrush integration
AHREFS_API_KEY=                    # Optional — for Ahrefs integration

# ── Evidence Collection (Phase 1) ────────────────────────────────────────────
GITHUB_TOKEN=                      # Optional — for GitHub repo evidence (stars, forks, issues)
#   Generate: https://github.com/settings/tokens (no special scopes needed for public repos)

# =============================================================================
# DEPRECATED — No longer referenced in source code. Will be removed in a future
# cleanup pass. Remove from your .env if present.
# =============================================================================
# GOOGLE_OAUTH_CLIENT_ID       — OAuth not implemented
# GOOGLE_OAUTH_CLIENT_SECRET   — OAuth not implemented
# scrape.do_api_key            — Dead service (use Firecrawl/Jina instead)
# serp_api_key                 — Dead service
# built_with_api_key           — Dead service
# hunter.io_api_key            — Dead service
# news_api_key                 — Dead service
# apify_api_key                — Dead service
# google_pagespeed_insights_api_key — Duplicate of PAGESPEED_API_KEY
