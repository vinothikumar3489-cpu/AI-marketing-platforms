  linkedInPosts       Json?
  linkedInDmTemplates Json?
  linkedInSchedule    Json?

  // Instagram Automation
  instagramCaptions  Json?
  instagramReelIdeas Json?
  instagramSchedule  Json?
  instagramHashtags  Json?

  // Creative Generation
  posterPrompts Json?
  imageAdIdeas  Json?
  designStyles  Json?

  // Video Ad Generation
  videoScripts  Json?
  videoScenes   Json?
  videoSchedule Json?

  // Campaign Generation
  googleAds       Json?
  contentCalendar Json?
  crmWorkflows    Json?
  workflows       Json?

  // Lead Generation
  idealLeadProfile Json?
  leadSources      Json?
  outreachAngles   Json?
  sampleLeads      Json?

  // Phase 6 — Marketing Execution Platform
  contentStudio   Json? // Blog articles, landing pages, case studies, etc.
  emailCampaigns  Json? // Email campaign drafts with compliance checklists
  creativeStudio  Json? // Creative briefs for posters, banners, carousels, etc.
