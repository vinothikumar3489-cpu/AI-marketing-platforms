// ============================================
// EMAIL CAMPAIGN MODULE (Phase 16)
// ============================================

model EmailCampaign {
  id             String        @id @default(cuid())
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  chat           Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId         String
  campaignPlan   CampaignPlan? @relation(fields: [campaignPlanId], references: [id], onDelete: SetNull)
  campaignPlanId String?

  name            String
  objective       String?
  audienceSummary String?
  funnelStage     String?
  sequenceType    String?
  senderName      String?
  senderEmail     String?
  replyToEmail    String?
  totalEmails     Int     @default(0)

  status           String @default("DRAFT")
  approvalStatus   String @default("NOT_SUBMITTED")
  generationStatus String @default("pending")

  evidenceSummary Json?
  missingEvidence Json?

  sequenceItems EmailSequenceItem[]
  versions      EmailCampaignVersion[]
  logs          EmailCampaignLog[]
  crmDeals      CRMDeal[]
  crmWorkflows  CRMWorkflow[]
  automations   EmailAutomation[]
  schedules     EmailSchedule[]
  deliveryLogs  EmailDeliveryLog[]
  emailEvents   EmailEvent[]

  approvedAt  DateTime?
  scheduledAt DateTime?
  submittedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chatId])
  @@index([userId])
  @@index([campaignPlanId])
  @@index([status])
  @@index([approvalStatus])
}

model EmailSequenceItem {
  id              String        @id @default(cuid())
  campaign        EmailCampaign @relation(fields: [emailCampaignId], references: [id], onDelete: Cascade)
  emailCampaignId String

  sequenceOrder          Int
  emailName              String
  purpose                String?
  funnelStage            String?
  delayAfterPreviousDays Int?    @default(0)

  subjectLine             String?
  alternativeSubjectLines Json?
  previewText             String?
  greetingStrategy        String?
  emailBodyText           String? @db.Text
  emailBodyHtml           String? @db.Text
  primaryCta              String?
  secondaryCta            String?
  personalizationFields   Json?

  evidenceUsed    Json?
  inferenceStatus String?
  complianceNotes String? @db.Text

  responsiveHtml String? @db.Text
  preview        Json?

  status String @default("draft")

  logEntries   EmailCampaignLog[]
  deliveryLogs EmailDeliveryLog[]
  emailEvents  EmailEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([emailCampaignId, sequenceOrder])
}

// ============================================
// EMAIL TEMPLATES (Reusable templates)
// ============================================

model EmailTemplate {
  id     String  @id @default(cuid())
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  chat   Chat?   @relation(fields: [chatId], references: [id], onDelete: SetNull)
  chatId String?

  name                  String
  description           String?
  category              String? // newsletter, promotional, transactional, onboarding, reengagement
  subjectLine           String?
  previewText           String?
  emailBodyText         String? @db.Text
  emailBodyHtml         String? @db.Text
  responsiveHtml        String? @db.Text
  personalizationFields Json?

  // Brand settings
  senderName     String?
  senderEmail    String?
  replyToEmail   String?
  headerImageUrl String?
  footerText     String?
  socialLinks    Json?
  brandColors    Json?

  useCount  Int     @default(0)
  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([category])
  @@index([chatId])
}

// ============================================
// EMAIL AUTOMATION RULES
// ============================================

model EmailAutomation {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId String

  name          String
  description   String?
  triggerType   String // schedule, campaign_approval, form_submission, lead_created, deal_stage_change
  triggerConfig Json? // { field, operator, value, schedule }
  conditions    Json? // [{ field, operator, value }]
  actions       Json? // [{ type: 'send_email', templateId, delay, config }]

  status          String @default("DRAFT") // DRAFT, ACTIVE, PAUSED, COMPLETED, FAILED
  executionStatus String @default("never_run")

  campaign        EmailCampaign? @relation(fields: [emailCampaignId], references: [id], onDelete: SetNull)
  emailCampaignId String?

  schedules    EmailSchedule[]
  deliveryLogs EmailDeliveryLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chatId])
  @@index([userId])
  @@index([status])
}

// ============================================
// EMAIL SCHEDULE
// ============================================

model EmailSchedule {
  id                String           @id @default(cuid())
  automation        EmailAutomation? @relation(fields: [emailAutomationId], references: [id], onDelete: Cascade)
  emailAutomationId String?
  campaign          EmailCampaign?   @relation(fields: [emailCampaignId], references: [id], onDelete: Cascade)
  emailCampaignId   String?

  scheduleType   String // once, daily, weekly, monthly, custom
  scheduledAt    DateTime?
  timezone       String?
  dayOfWeek      Int?
  dayOfMonth     Int?
  timeOfDay      String?
  cronExpression String?
  startDate      DateTime?
  endDate        DateTime?
  repeatCount    Int?      @default(1)
  repeatInterval Int? // in days

  status String @default("pending") // pending, scheduled, running, completed, cancelled, failed

  lastRunAt   DateTime?
  nextRunAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([emailAutomationId])
  @@index([emailCampaignId])
  @@index([status])
  @@index([nextRunAt])
}

// ============================================
// EMAIL DELIVERY LOG
// ============================================

model EmailDeliveryLog {
  id String @id @default(cuid())

  campaign            EmailCampaign?     @relation(fields: [emailCampaignId], references: [id], onDelete: Cascade)
  emailCampaignId     String?
  sequenceItem        EmailSequenceItem? @relation(fields: [emailSequenceItemId], references: [id], onDelete: SetNull)
  emailSequenceItemId String?
  automation          EmailAutomation?   @relation(fields: [emailAutomationId], references: [id], onDelete: SetNull)
  emailAutomationId   String?

  recipientEmail    String
  recipientName     String?
  provider          String // brevo, sendgrid, resend, gmail_smtp
  providerMessageId String?
  subjectLine       String?

  status         String // pending, sent, delivered, opened, clicked, bounced, failed, spam, unsubscribed
  previousStatus String?
  errorMessage   String? @db.Text
  errorCategory  String? // rate_limit, invalid_email, provider_error, authentication, unknown

  attemptCount  Int       @default(1)
  maxAttempts   Int       @default(3)
  lastAttemptAt DateTime?
  sentAt        DateTime?
  deliveredAt   DateTime?
  openedAt      DateTime?
  clickedAt     DateTime?
  bouncedAt     DateTime?

  metadata Json? // provider response, headers, tracking data

  eventHistory Json? // [{ status, timestamp, detail }]

  emailEvents EmailEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([emailCampaignId])
  @@index([emailSequenceItemId])
  @@index([recipientEmail])
  @@index([status])
  @@index([providerMessageId])
  @@index([emailAutomationId])
}

// ============================================
// EMAIL EVENTS (Tracking webhook events)
// ============================================

model EmailEvent {
  id                  String             @id @default(cuid())
  deliveryLog         EmailDeliveryLog?  @relation(fields: [emailDeliveryLogId], references: [id], onDelete: Cascade)
  emailDeliveryLogId  String?
  campaign            EmailCampaign?     @relation(fields: [emailCampaignId], references: [id], onDelete: Cascade)
  emailCampaignId     String?
  sequenceItem        EmailSequenceItem? @relation(fields: [emailSequenceItemId], references: [id], onDelete: SetNull)
  emailSequenceItemId String?

  eventType       String // sent, delivered, opened, clicked, bounced, complained, unsubscribed, failed
  eventData       Json? // provider-specific event data
  provider        String? // brevo, sendgrid, resend
  providerEventId String?
  recipientEmail  String?
  userAgent       String?
  ipAddress       String?
  linkClicked     String? // for click events
  bounceType      String? // hard, soft
  bounceReason    String? @db.Text

  occurredAt DateTime?
  receivedAt DateTime  @default(now())

  @@index([emailDeliveryLogId])
  @@index([emailCampaignId])
  @@index([eventType])
  @@index([providerEventId])
  @@index([occurredAt])
}

model EmailCampaignVersion {
  id              String        @id @default(cuid())
  campaign        EmailCampaign @relation(fields: [emailCampaignId], references: [id], onDelete: Cascade)
  emailCampaignId String

  versionNumber Int
  snapshot      Json
  changeReason  String? @db.Text
  createdBy     String?

  createdAt DateTime @default(now())

  @@index([emailCampaignId, versionNumber])
}

model EmailCampaignLog {
  id                  String             @id @default(cuid())
  campaign            EmailCampaign      @relation(fields: [emailCampaignId], references: [id], onDelete: Cascade)
  emailCampaignId     String
  sequenceItem        EmailSequenceItem? @relation(fields: [emailSequenceItemId], references: [id], onDelete: SetNull)
  emailSequenceItemId String?

  action   String
  status   String?
  message  String? @db.Text
  metadata Json?

  createdAt DateTime @default(now())

  @@index([emailCampaignId, action])
}

// ============================================
// CRM MODULE (Phase 17 — CRM Workflow & Lead Journey Automation)
// ============================================

model CRMContact {
  id        String      @id @default(cuid())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  chat      Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId    String
  company   CRMCompany? @relation("ContactCompany", fields: [companyId], references: [id], onDelete: SetNull)
  companyId String?

  firstName      String
  lastName       String?
  email          String?
  phone          String?
  jobTitle       String?
  lifecycleStage String  @default("NOT_MEASURED")
  source         String?
  consentStatus  String  @default("NOT_MEASURED")
  ownerId        String?
  status         String  @default("ACTIVE")
  customFields   Json?

  deals                CRMDeal[]
  activities           CRMActivity[]
  tasks                CRMTask[]
  workflowExecutions   CRMWorkflowExecution[]
  salesCopilotMemories SalesCopilotMemory[]
  proposals            Proposal[]
  healthSnapshots      CustomerHealthSnapshot[]

  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([chatId])
  @@index([userId])
  @@index([email])
  @@index([status])
  @@index([lifecycleStage])
  @@index([companyId])
}

model CRMCompany {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId String

  name          String
  website       String?
  industry      String?
  employeeRange String?
  location      String?
  description   String?
  source        String?
  customFields  Json?

  contacts             CRMContact[]             @relation("ContactCompany")
  deals                CRMDeal[]
  activities           CRMActivity[]
  tasks                CRMTask[]
  workflowExecutions   CRMWorkflowExecution[]
  salesCopilotMemories SalesCopilotMemory[]
  proposals            Proposal[]
  healthSnapshots      CustomerHealthSnapshot[]

  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([chatId])
  @@index([userId])
  @@index([name])
}

model CRMPipeline {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId String

  name        String
  description String?
  status      String  @default("ACTIVE")

  stages CRMPipelineStage[]
  deals  CRMDeal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chatId])
  @@index([userId])
}

model CRMPipelineStage {
  id         String      @id @default(cuid())
  pipeline   CRMPipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  pipelineId String

  name        String
  order       Int
  description String?
  stageType   String? // lead, qualified, contacted, meeting, proposal, won, lost
  isClosed    Boolean @default(false)

  deals CRMDeal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pipelineId, order])
}

model CRMDeal {
  id              String            @id @default(cuid())
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  chat            Chat              @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId          String
  company         CRMCompany?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  companyId       String?
  contact         CRMContact?       @relation(fields: [contactId], references: [id], onDelete: SetNull)
  contactId       String?
  pipeline        CRMPipeline?      @relation(fields: [pipelineId], references: [id], onDelete: SetNull)
  pipelineId      String?
  stage           CRMPipelineStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)
  stageId         String?
  campaignPlan    CampaignPlan?     @relation(fields: [campaignPlanId], references: [id], onDelete: SetNull)
  campaignPlanId  String?
  emailCampaign   EmailCampaign?    @relation(fields: [emailCampaignId], references: [id], onDelete: SetNull)
  emailCampaignId String?

  name              String
  description       String?
  currency          String?   @default("USD")
  value             Float?
  expectedCloseDate DateTime?
  status            String    @default("OPEN")
  source            String?
  ownerId           String?
  metadata          Json?

  activities           CRMActivity[]
  tasks                CRMTask[]
  workflowExecutions   CRMWorkflowExecution[]
  salesCopilotMemories SalesCopilotMemory[]
  dealInsights         DealInsight[]
  proposals            Proposal[]
  healthSnapshots      CustomerHealthSnapshot[]

  archivedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([chatId])
  @@index([userId])
  @@index([pipelineId, stageId])
  @@index([status])
  @@index([contactId])
  @@index([companyId])
  @@index([campaignPlanId])
  @@index([expectedCloseDate])
  @@index([ownerId])
  @@index([updatedAt])
}

model CRMActivity {
  id        String      @id @default(cuid())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  chat      Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId    String
  contact   CRMContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  contactId String?
  company   CRMCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  companyId String?
  deal      CRMDeal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  dealId    String?

  activityType String // note, call, meeting, email, stage_change, task_completion, campaign_association, workflow_execution
  title        String
  description  String?  @db.Text
  activityDate DateTime @default(now())
  outcome      String?
  source       String? // MANUALLY_RECORDED, PROVIDER_DELIVERED, IMPORTED, SYSTEM
  createdBy    String?

  provider          String? // email provider name if provider-delivered
  providerMessageId String? // provider's tracking ID if provider-delivered
  deliveryStatus    String? // sent, delivered, bounced, failed — only for provider-delivered
  metadata          Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chatId])
  @@index([userId])
  @@index([contactId])
  @@index([companyId])
  @@index([dealId])
  @@index([activityType])
  @@index([activityDate])
  @@index([chatId, activityDate])
}

model CRMTask {
  id        String      @id @default(cuid())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  chat      Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId    String
  contact   CRMContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  contactId String?
  company   CRMCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  companyId String?
  deal      CRMDeal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  dealId    String?

  assignedTo  String?
  title       String
  description String?   @db.Text
  priority    String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status      String    @default("TODO") // TODO, IN_PROGRESS, COMPLETED, CANCELLED
  dueAt       DateTime?
  completedAt DateTime?
  source      String? // MANUAL, WORKFLOW, IMPORT, AI_RECOMMENDATION

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chatId])
  @@index([userId])
  @@index([contactId])
  @@index([dealId])
  @@index([status])
  @@index([assignedTo])
  @@index([dueAt])
  @@index([chatId, status, dueAt])
}

model CRMWorkflow {
  id              String         @id @default(cuid())
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String
  chat            Chat           @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId          String
  campaignPlan    CampaignPlan?  @relation(fields: [campaignPlanId], references: [id], onDelete: SetNull)
  campaignPlanId  String?
  emailCampaign   EmailCampaign? @relation(fields: [emailCampaignId], references: [id], onDelete: SetNull)
  emailCampaignId String?

  name          String
  description   String? @db.Text
  triggerType   String // CONTACT_CREATED, CONTACT_UPDATED, DEAL_CREATED, DEAL_STAGE_CHANGED, TASK_COMPLETED, EMAIL_CAMPAIGN_APPROVED, DATE_REACHED, MANUAL_TRIGGER
  triggerConfig Json? // { field, operator, value }
  conditions    Json? // [{ field, operator, value }]
  actions       Json? // [{ type, config }]

  status          String @default("DRAFT") // DRAFT, READY_FOR_REVIEW, APPROVED, ACTIVE, PAUSED, COMPLETED, FAILED, ARCHIVED
  approvalStatus  String @default("NOT_SUBMITTED") // NOT_SUBMITTED, PENDING_REVIEW, CHANGES_REQUESTED, APPROVED, REJECTED
  executionStatus String @default("never_run") // never_run, running, completed, failed, paused

  versionNumber  Int     @default(1)
  maxDepth       Int     @default(10)
  maxActions     Int     @default(20)
  idempotencyKey String?

  approvedAt  DateTime?
  pausedAt    DateTime?
  activatedAt DateTime?

  versions   CRMWorkflowVersion[]
  executions CRMWorkflowExecution[]
  logs       CRMWorkflowLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chatId])
  @@index([userId])
  @@index([campaignPlanId])
  @@index([status])
  @@index([approvalStatus])
}

model CRMWorkflowVersion {
  id         String      @id @default(cuid())
  workflow   CRMWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workflowId String

  versionNumber Int
  snapshot      Json // full workflow + conditions + actions
  changeReason  String? @db.Text
  createdBy     String?

  createdAt DateTime @default(now())

  @@index([workflowId, versionNumber])
}

model CRMWorkflowExecution {
  id         String      @id @default(cuid())
  workflow   CRMWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workflowId String
  contact    CRMContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  contactId  String?
  company    CRMCompany? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  companyId  String?
  deal       CRMDeal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  dealId     String?

  status         String  @default("pending") // pending, running, completed, failed, cancelled
  currentStep    Int     @default(0)
  maxSteps       Int     @default(10)
  executionData  Json? // { triggerResult, conditionResults, actionResults }
  errorMessage   String? @db.Text
  idempotencyKey String?

  workflowLogs CRMWorkflowLog[]

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workflowId])
  @@index([status])
  @@index([idempotencyKey])
}

model CRMWorkflowLog {
  id          String                @id @default(cuid())
  workflow    CRMWorkflow           @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workflowId  String
  execution   CRMWorkflowExecution? @relation(fields: [executionId], references: [id], onDelete: SetNull)
  executionId String?

  action   String // workflow_created, submitted_review, approved, changes_requested, activated, paused, completed, failed, execution_started, execution_step, execution_completed, execution_failed, cancelled, version_created, version_restored
  status   String?
  message  String? @db.Text
  metadata Json?

  createdAt DateTime @default(now())

  @@index([workflowId, action])
}

model CRMImportJob {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId String

  fileName      String
  fileType      String // csv
  status        String @default("UPLOADED") // UPLOADED, PARSED, MAPPED, VALIDATED, CONFIRMED, IMPORTING, COMPLETED, FAILED, CANCELLED
  totalRows     Int    @default(0)
  validRows     Int    @default(0)
  invalidRows   Int    @default(0)
  importedRows  Int    @default(0)
  duplicateRows Int    @default(0)
  errorRows     Int    @default(0)

  columnMapping     Json? // { sourceColumn -> targetField }
  validationSummary Json? // [{ row, errors }]
  errorDetails      Json? // [{ row, field, message }]
  duplicateStrategy String @default("SKIP_EXISTING") // SKIP_EXISTING, UPDATE_EMPTY_FIELDS, UPDATE_ALL_MAPPED_FIELDS, CREATE_DUPLICATE

  importType String // contact, company
  parsedData Json? // raw parsed rows for preview
  mappedData Json? // rows after column mapping

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([chatId])
  @@index([userId])
  @@index([status])
}

