generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                   @id @default(cuid())
  name                    String
  email                   String                   @unique
  password                String
  profileImage            String?
  role                    String?                  @default("member")
  lastActiveAt            DateTime?
  chats                   Chat[]
  analyses                Analysis[]
  seoAnalyses             SeoAnalysis[]
  productProfiles         ProductProfile[]
  productAnalyses         ProductAnalysis[]
  productIntelligence     ProductIntelligence[]
  competitorIntelligence  CompetitorIntelligence[]
  campaignIntelligence    CampaignIntelligence[]
  seoIntelligence         SeoIntelligence[]
  agentRuns               AgentRun[]
  notifications           Notification[]
  automationPlans         AutomationPlan[]
  automationLogs          AutomationLog[]
  executionRecords        ExecutionRecord[]
  evidenceSnapshots       EvidenceSnapshot[]
  campaignPlans           CampaignPlan[]
  emailCampaigns          EmailCampaign[]
  emailTemplates          EmailTemplate[]
  emailAutomations        EmailAutomation[]
  crmContacts             CRMContact[]
  crmCompanies            CRMCompany[]
  crmDeals                CRMDeal[]
  crmActivities           CRMActivity[]
  crmTasks                CRMTask[]
  crmPipelines            CRMPipeline[]
  crmWorkflows            CRMWorkflow[]
  crmImportJobs           CRMImportJob[]
  salesCopilotMemories    SalesCopilotMemory[]
  dealInsights            DealInsight[]
  proposals               Proposal[]
  customerHealthSnapshots CustomerHealthSnapshot[]

  // Growth Execution Layer relations
  growthSprints GrowthSprint[]
  growthTasks   GrowthTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Chat {
  id                     String                  @id @default(cuid())
  user                   User                    @relation(fields: [userId], references: [id])
  userId                 String
  title                  String
  productName            String?
  messages               Message[]
  analysis               Analysis[]
  seoAnalysis            SeoAnalysis?
  productProfile         ProductProfile?
  productAnalysis        ProductAnalysis?
  productIntelligence    ProductIntelligence?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  competitorIntelligence CompetitorIntelligence?
  campaignIntelligence   CampaignIntelligence?

  seoIntelligence SeoIntelligence?
  AgentRun        AgentRun[]
  automationPlan  AutomationPlan?

  // Growth Execution Layer relations
  growthSprints           GrowthSprint[]
  growthTasks             GrowthTask[]
  executionRecords        ExecutionRecord[]
  evidenceSnapshots       EvidenceSnapshot[]
  campaignPlans           CampaignPlan[]
  emailCampaigns          EmailCampaign[]
  emailTemplates          EmailTemplate[]
  emailAutomations        EmailAutomation[]
  crmContacts             CRMContact[]
  crmCompanies            CRMCompany[]
  crmDeals                CRMDeal[]
  crmActivities           CRMActivity[]
  crmTasks                CRMTask[]
  crmPipelines            CRMPipeline[]
  crmWorkflows            CRMWorkflow[]
  crmImportJobs           CRMImportJob[]
  salesCopilotMemories    SalesCopilotMemory[]
  dealInsights            DealInsight[]
  proposals               Proposal[]
  customerHealthSnapshots CustomerHealthSnapshot[]

  @@index([userId])
}

model Message {
  id           String   @id @default(cuid())
  chat         Chat     @relation(fields: [chatId], references: [id])
  chatId       String
  role         String
  content      String
  analysisData Json?
  createdAt    DateTime @default(now())

  @@index([chatId])
}

model Analysis {
  id                  String             @id @default(cuid())
  chat                Chat               @relation(fields: [chatId], references: [id])
  chatId              String
  user                User               @relation(fields: [userId], references: [id])
  userId              String
  productName         String
  productDescription  String
  targetAudience      String
  marketInsights      Json?
  competitorInsights  Json?
  campaignSuggestions Json?
  roiSuggestions      Json?
  evidenceSnapshots   EvidenceSnapshot[]
  createdAt           DateTime           @default(now())

  @@index([chatId])
  @@index([userId])
}

model SeoAnalysis {
  id                 String   @id @default(cuid())
  chat               Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId             String
  websiteUrl         String?
  seoScore           Int?
  visibilityScore    Int?
  organicTraffic     Int?
  backlinkCount      Int?
  keywordCount       Int?
  avgPosition        Float?
  ctr                Float?
  topKeywords        Json?
  competitorKeywords Json?
  backlinks          Json?
  trafficEstimate    Json?
  technicalIssues    Json?
  contentSuggestions Json?
  prediction         Json?
  source             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
  @@index([chatId])
}

model Notification {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model ProductProfile {
  id             String   @id @default(cuid())
  chat           Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  productName    String
  companyName    String?
  websiteUrl     String?
  description    String?
  industry       String?
  targetAudience String?
  pricing        String?
  competitors    String?
  businessGoal   String?
  scrapedData    Json?
  mergedData     Json?
  scrapeStatus   String   @default("pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([chatId])
}

model ProductAnalysis {
  id                  String   @id @default(cuid())
  chat                Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId              String
  productSummary      String?
  category            String?
  confidenceScore     Int?
  usp                 Json?
  features            Json?
  benefits            Json?
  painPoints          Json?
  targetUsers         Json?
  competitorTypes     Json?
  competitors         Json?
  directCompetitors   Json?
  indirectCompetitors Json?
  emergingCompetitors Json?
  businessModel       String?
  revenueModel        String?
  marketSegment       String?
  pricingPosition     String?
  marketMaturity      String?
  marketingAngles     Json?
  seoOpportunities    Json?
  campaignIdeas       Json?
  recommendedChannels Json?
  confidenceBreakdown Json?
  recommendedModules  Json?
  apiStatus           Json?
  buyerPersonas       Json?
  dataSourcesUsed     Json?
  providers           Json?
  aiWarnings          Json?
  warnings            Json?
  source              String?
  useCases            Json?
  customerSegments    Json?
  testimonials        Json?
  caseStudies         Json?
  technologyStack     Json?
  schemaOrg           Json?
  faq                 Json?
  resources           Json?
  // Custom fields for our new flow
  provider            String?
  fallbackUsed        Boolean? @default(false)
  inputJson           Json?
  outputJson          Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
  @@index([chatId])
}

model ProductIntelligence {
  id     String @id @default(cuid())
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  productAnalysis      Json?
  marketDiscovery      Json?
  audienceIntelligence Json?

  // Common fields for all modules
  provider     String?
  fallbackUsed Boolean? @default(false)
  inputJson    Json?
  status       String?  @default("pending")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([chatId])
}

model CompetitorIntelligence {
  id     String @id @default(cuid())
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  competitorAnalysis Json?
  intentPrediction   Json?
  positioningEngine  Json?

  // Custom fields for our new flow
  provider     String?
  fallbackUsed Boolean? @default(false)
  inputJson    Json?
  status       String?  @default("pending")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([chatId])
}

model CampaignIntelligence {
  id     String @id @default(cuid())
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  campaignGenerator     Json?
  channelRecommendation Json?
  executiveStory        Json?
  actionPlan            Json?

  provider     String?
  fallbackUsed Boolean? @default(false)
  inputJson    Json?
  status       String?  @default("pending")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([chatId])
}

model CampaignPlan {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId String @unique

  // Campaign Intelligence (all derived from evidence, never fabricated)
  executiveSummary       Json? // campaignName, campaignTheme, campaignGoal, duration, primaryAudience, primaryChannels, topOpportunities, topRisks, nextActions
  businessGoal           Json? // goal, confidence, reason, evidence
  campaignObjective      Json? // primary, secondary, successDefinition, targetAudience, idealCustomer, timeline, priority, dependencies
  audienceSelection      Json? // primary, secondary, buyingStage, painPoints, decisionDrivers, objections, contentPreferences
  channelRecommendations Json? // [{ channel, fit, priority, reason, evidence, recommendedContent, recommendedCTA, organicOrPaid }]
  timeline               Json? // week1, week2, week3, week4, month2, month3 — each with tasks
  marketingFunnel        Json? // awareness, interest, consideration, conversion, retention, advocacy
  kpiFramework           Json? // [{ kpi, howToMeasure, tool, frequency, status }]
  riskAssessment         Json? // [{ risk, cause, evidence, severity, mitigation }]
  opportunityAssessment  Json? // [{ opportunity, reason, evidence, effort, priority, expectedBusinessImpact }]
  nextActions            Json? // [{ action, owner, priority, evidence }]

  // Metadata
  status       String?  @default("draft")
  provider     String?
  fallbackUsed Boolean? @default(false)
  inputJson    Json?
  version      Int?     @default(1)

  emailCampaigns EmailCampaign[]
  crmDeals       CRMDeal[]
  crmWorkflows   CRMWorkflow[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chatId])
  @@index([userId])
}

// ============================================
// GROWTH WORKSPACE EXECUTION MODELS
// ============================================

model GrowthSprint {
  id        String       @id @default(cuid())
  chat      Chat         @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  name      String // e.g., "Immediate", "Day 7", "This Month"
  startDate DateTime?
  endDate   DateTime?
  status    String       @default("active") // active, completed, planned
  tasks     GrowthTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chatId])
  @@index([userId])
}

model GrowthTask {
  id       String        @id @default(cuid())
  chat     Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId   String
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  sprint   GrowthSprint? @relation(fields: [sprintId], references: [id])
  sprintId String?

  title       String
  description String? @db.Text
  status      String  @default("todo") // todo, in_progress, in_review, done
  priority    String  @default("Medium") // High, Medium, Low, Critical
  difficulty  String? // Hard, Medium, Easy
  impact      String? // Business value / Impact description
  owner       String? @default("Marketing Team")
  kpi         String?

  estimatedTime String? // e.g., "3 hours", "2 days"
  targetKeyword String?
  affectedPage  String?

  // Progress tracking
  progress    Int       @default(0) // 0-100
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  dueDate     DateTime?

  // Generative AI Context
  aiGeneratedType String? // e.g., "meta_tags", "blog_post", "faq"
  aiPromptContext Json? // Stores the context needed to run inline generation

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chatId])
  @@index([userId])
  @@index([sprintId])
}

model SeoIntelligence {
  id     String @id @default(cuid())
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  websiteUrl             String?
  domain                 String?
  companyName            String?
  productName            String?
  analyzedAt             DateTime? @default(now())
  seoScore               Int?
  technicalAudit         Json?
  keywordOpportunities   Json?
  competitorKeywords     Json?
  contentGaps            Json?
  aiVisibility           Json?
  landingPageSuggestions Json?
  blogIdeas              Json?
  actionPlan             Json?

  // Metadata
  providers    Json?
  warnings     Json?
  status       String?  @default("pending")
  fallbackUsed Boolean? @default(false)
  inputJson    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // New Relations for Enhanced SEO + GEO
  rawCrawlData           RawCrawlData[]
  technicalAuditDetail   TechnicalSeoAudit?
  scoreBreakdown         SeoScoreBreakdown?
  keywordIntelligence    KeywordIntelligenceRecord?
  topicClusters          TopicCluster[]
  seoCompetitors         SeoCompetitorIntelligence[]
  geoIntelligence        GeoIntelligenceRecord?
  competitorSeoRecord    CompetitorSeoRecord?
  contentGapDetails      ContentGap[]
  blogIntelligenceItems  BlogIntelligence[]
  contentGapRecord       ContentGapRecord?
  blogIntelligenceRecord BlogIntelligenceRecord?
  executiveDashboard     ExecutiveSeoDashboard?

  @@index([userId])
  @@index([chatId])
}

// ============================================
// RAW CRAWL DATA
// ============================================

model RawCrawlData {
  id                String          @id @default(cuid())
  seoIntelligence   SeoIntelligence @relation(fields: [seoIntelligenceId], references: [id], onDelete: Cascade)
  seoIntelligenceId String

  url        String
  html       String   @db.Text
  text       String   @db.Text
  metadata   Json
  technical  Json
  content    Json
  structured Json
  provider   String
  scrapedAt  DateTime @default(now())

  @@index([seoIntelligenceId])
}

// ============================================
// TECHNICAL SEO AUDIT (DETAILED)
// ============================================

model TechnicalSeoAudit {
  id                String          @id @default(cuid())
  seoIntelligence   SeoIntelligence @relation(fields: [seoIntelligenceId], references: [id], onDelete: Cascade)
  seoIntelligenceId String          @unique

  // Full audit data structure
  auditData Json

  // Individual scores for quick access (null if evidence not available)
  overallScore  Int?
  titleScore    Int?
  metaScore     Int?
  securityScore Int?
  mobileScore   Int?
  headingScore  Int?
  schemaScore   Int?

  // Issues by priority
  criticalIssues Json
  highIssues     Json
  mediumIssues   Json
  lowIssues      Json

  // Recommendations
  recommendations Json

  analyzedAt DateTime @default(now())
}

// ============================================
// SEO SCORE BREAKDOWN
// ============================================

model SeoScoreBreakdown {
  id                String          @id @default(cuid())
  seoIntelligence   SeoIntelligence @relation(fields: [seoIntelligenceId], references: [id], onDelete: Cascade)
  seoIntelligenceId String          @unique

  // Dimensional scores (null if evidence not available)
  technicalScore    Int?
  onPageScore       Int?
  contentScore      Int?
  authorityScore    Int?
  aiVisibilityScore Int?
  localSeoScore     Int?
  overallScore      Int?

  // Score history for trend tracking
  scoreHistory Json?

  lastCalculated DateTime @default(now())
}

// ============================================
// KEYWORD INTELLIGENCE (Consolidated Model)
// ============================================

model KeywordIntelligenceRecord {
  id                String          @id @default(cuid())
  seoIntelligence   SeoIntelligence @relation(fields: [seoIntelligenceId], references: [id], onDelete: Cascade)
  seoIntelligenceId String          @unique

  // Keyword Categories (JSON arrays of keyword objects)
  primaryKeywords   Json // [{ keyword, intent, difficulty, opportunity, confidenceScore, reason }]
  secondaryKeywords Json // [{ keyword, intent, difficulty, opportunity, confidenceScore, reason }]
  longTailKeywords  Json // [{ keyword, intent, difficulty, opportunity, confidenceScore, reason }]
  questionKeywords  Json // [{ keyword, intent, difficulty, opportunity, confidenceScore, reason }]

  // Topic Clusters
  clusters Json // [{ name, keywords[], priority, contentSuggestions[] }]

  // Competitor Keywords
  competitorKeywords Json // [{ keyword, competitorUsing, reason, opportunity, intent, difficulty }]

  // Content Opportunities
  contentOpportunities Json // [{ keyword, pageSuggestion, reason, impact, type, priority }]

  // GEO Keywords (AI Search Optimization)
  geoKeywords Json // [{ question, platform, answerOpportunity, contentSuggestion, intent }]

  // Metadata
  totalKeywords      Int? @default(0)
  clustersCount      Int? @default(0)
  opportunitiesCount Int? @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([seoIntelligenceId])
}

// ============================================
// TOPIC CLUSTERS
// ============================================

model TopicCluster {
  id                String          @id @default(cuid())
  seoIntelligence   SeoIntelligence @relation(fields: [seoIntelligenceId], references: [id], onDelete: Cascade)
  seoIntelligenceId String

  name               String
  keywords           Json // array of keyword IDs or strings
  priority           Int
  contentSuggestions Json

  createdAt DateTime @default(now())

  @@index([seoIntelligenceId, priority])
}

// ============================================
// SEO COMPETITOR INTELLIGENCE
// ============================================

model SeoCompetitorIntelligence {
  id                String          @id @default(cuid())
  seoIntelligence   SeoIntelligence @relation(fields: [seoIntelligenceId], references: [id], onDelete: Cascade)
  seoIntelligenceId String

  name    String
  website String
  type    String // direct, indirect
  reason  String @db.Text

  // Analysis
  strengths       Json
  weaknesses      Json
  contentStrategy String? @db.Text
  positioning     String? @db.Text
  seoAdvantages   Json

  // Gaps
  keywordGaps   Json
  contentGaps   Json
  authorityGaps Json

  authorityEstimate Int?
  createdAt         DateTime @default(now())

  @@index([seoIntelligenceId, type])
}

// ============================================
// GEO INTELLIGENCE (Generative Engine Optimization)
// ============================================

model GeoIntelligenceRecord {
  id                String          @id @default(cuid())
  seoIntelligence   SeoIntelligence @relation(fields: [seoIntelligenceId], references: [id], onDelete: Cascade)
  seoIntelligenceId String          @unique

  // Overall AI Visibility Score (null if not measured)
  aiVisibilityScore Int?

  // Individual Platform Scores (null if not measured)
  chatGptScore          Int?
  geminiScore           Int?
  claudeScore           Int?
  perplexityScore       Int?
  googleAiOverviewScore Int?

  // Component Scores (null if not measured)
  entityCoverageScore          Int?
  knowledgeGraphReadinessScore Int?
  citationReadinessScore       Int?
  answerabilityScore           Int?
  topicalAuthorityScore        Int?

  // Detailed Analysis Data (JSON)
  entities               Json // [{ entity, type, confidenceScore, context }]
  knowledgeGraphEntities Json // [{ type, status }]
  citationOpportunities  Json // [{ type, opportunity, impact, reason }]
  faqOpportunities       Json // [{ question, reason, impact, recommendation }]
  aiContentOpportunities Json // [{ type, opportunity, reason, impact, difficulty, priority }]
  trustSignals           Json // { score, signals, recommendations }
  recommendations        Json // { immediate, day30, day90 }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([seoIntelligenceId])
}

// ============================================
// CONTENT GAPS
// ============================================

model ContentGap {
  id                String          @id @default(cuid())
  seoIntelligence   SeoIntelligence @relation(fields: [seoIntelligenceId], references: [id], onDelete: Cascade)
  seoIntelligenceId String

  type             String // missing-topic, missing-page, missing-blog, missing-use-case, missing-faq
  title            String
  reason           String  @db.Text
  opportunityScore Int?
  priority         String // critical, high, medium, low
  competitors      Json // which competitors have this
  suggestedPage    String? @db.Text

  createdAt DateTime @default(now())

  @@index([seoIntelligenceId, opportunityScore])
}

// ============================================
// BLOG INTELLIGENCE
// ============================================

model BlogIntelligence {
  id                String          @id @default(cuid())
  seoIntelligence   SeoIntelligence @relation(fields: [seoIntelligenceId], references: [id], onDelete: Cascade)
  seoIntelligenceId String

  title           String
  keyword         String
  intent          String
  difficulty      String
  opportunity     String
  estimatedImpact String
  outline         Json?
  metaDescription String? @db.Text

  createdAt DateTime @default(now())

  @@index([seoIntelligenceId, opportunity])
}

// ============================================
// CONTENT GAP INTELLIGENCE (Consolidated Record)
// ============================================

model ContentGapRecord {
  id                String          @id @default(cuid())
  seoIntelligence   SeoIntelligence @relation(fields: [seoIntelligenceId], references: [id], onDelete: Cascade)
  seoIntelligenceId String          @unique

  // Missing Content & Pages
  contentGaps Json // [{ title, contentType, priority, opportunityScore, competitorExample, reason, suggestedAction, estimatedImpact }]

  // Landing Page Opportunities
  landingPageIdeas Json // [{ pageTitle, targetKeyword, intent, headline, subHeadline, keySections, CTA, trustElements, recommendedSchema, opportunityScore, priority }]

  // Comparison Page Opportunities
  comparisonPageIdeas Json // [{ title, targetKeyword, comparisonPoints, whyCreate, rankingPotential, opportunityScore, priority, estimatedImpact }]

  // FAQ Opportunities
  faqOpportunities Json // [{ question, answerIntent, targetAudience, geoPotential, seoPotential, reason, recommendedAnswer, priority }]

  // GEO Content Ideas (AI-Optimized)
  geoContentIdeas Json // [{ title, contentType, aiVisibilityImpact, citationPotential, answerabilityPotential, targetPlatforms, keySections, priority, estimatedImpact }]

  // Resource Page Ideas
  resourcePageIdeas Json // [{ title, contentType, targetKeyword, opportunityScore, priority, sections }]

  // Content Calendar (30/60/90 days)
  contentCalendar Json // { day30: [...], day60: [...], day90: [...] }

  // Summary Metrics
  summary Json // { totalGaps, totalOpportunities, criticalPriority, highPriority }

  // Metadata
  metadata Json? // { analyzedAt, analysisVersion }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([seoIntelligenceId])
}

// ============================================
// BLOG INTELLIGENCE (Consolidated Record)
// ============================================

model BlogIntelligenceRecord {
  id                String          @id @default(cuid())
  seoIntelligence   SeoIntelligence @relation(fields: [seoIntelligenceId], references: [id], onDelete: Cascade)
  seoIntelligenceId String          @unique

  // Blog Ideas (50+ ideas)
  blogIdeas Json // [{ title, targetKeyword, searchIntent, difficulty, opportunity, contentType, estimatedImpact, priority, reason }]

  // Blog Clusters
  blogClusters Json // [{ clusterName, authorityScore, blogIdeas, targetAudience, publishingFrequency }]

  // Blog Briefs (SEO Briefs for top ideas)
  blogBriefs Json // [{ title, primaryKeyword, secondaryKeywords, targetAudience, searchIntent, contentOutline, faqSuggestions, schemaSuggestions, internalLinkSuggestions, wordCountTarget, estimatedReadTime, priority }]

  // Publishing Calendar
  publishingCalendar Json // { week1: [...], week2: [...], week3: [...], week4: [...], month2: [...], month3: [...] }

  // Summary Metrics
  summary Json // { totalIdeas, totalClusters, highPriorityIdeas }

  // Metadata
  metadata Json? // { analyzedAt, analysisVersion }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([seoIntelligenceId])
}

// ============================================
// COMPETITOR SEO INTELLIGENCE
// ============================================

model CompetitorSeoRecord {
  id                String          @id @default(cuid())
  seoIntelligence   SeoIntelligence @relation(fields: [seoIntelligenceId], references: [id], onDelete: Cascade)
  seoIntelligenceId String          @unique

  // Discovered Competitors
  competitors Json // [{ name, website, description, competitorType, reason, confidenceScore, sources }]

  // Competitor Profiles
  competitorProfiles Json // [{ name, domain, website, mainKeywords, contentThemes, positioning, strengths, weaknesses, estimatedAuthority, aiVisibilityEstimate }]

  // Keyword Gaps
  keywordGaps Json // { missingKeywords, sharedKeywords, competitorOnlyKeywords, highOpportunityKeywords, lowCompetitionKeywords, summary }

  // Content Gaps
  contentGaps Json // [{ gapType, title, reason, competitorExample, opportunityScore, priority, suggestedAction }]

  // Authority Gaps
  authorityGaps Json // { authorityGapScore, userStrengths, competitorAdvantages, backlinkOpportunities, citationOpportunities, trustSignalGaps }

  // GEO Gaps
  geoGaps Json // { entityCoverageGap, citationReadinessGap, answerabilityGap, topicalAuthorityGap, aiVisibilityGap, recommendedFixes }

  // Competitor Matrix
  competitorMatrix Json // [{ name, website, keywordStrength, contentStrength, authorityStrength, geoStrength, overallThreatScore, weaknessToExploit, recommendedStrategy }]

  // Recommendations
  recommendations Json // { immediate, day30, day90, competitivePriorities }

  // Metadata
  metadata Json? // { totalCompetitors, directCompetitors, analyzedAt }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([seoIntelligenceId])
}

model AgentRun {
  id     String @id @default(cuid())
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  agentType String
  status    String
  input     Json?
  output    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chatId])
  @@index([userId])
}

// ============================================
