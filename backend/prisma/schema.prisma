// ============================================
// EVIDENCE SNAPSHOT (Phase 1 — Evidence Engine)
// ============================================

model EvidenceSnapshot {
  id         String    @id @default(cuid())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  chat       Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId     String
  analysis   Analysis? @relation(fields: [analysisId], references: [id], onDelete: SetNull)
  analysisId String?

  websiteUrl    String
  companyName   String?
  sourceSummary Json? // { sourcesCollected: [...], missingSources: [...] }

  // Evidence collections (all nullable — never fake)
  websiteEvidence      Json? // title, meta, headings, hero, CTA, features, page detection
  technicalSeoEvidence Json? // pagespeed scores, robots, sitemap
  contentEvidence      Json? // opengraph, schema, technology detection
  competitorEvidence   Json? // reserved for later
  githubEvidence       Json? // repo stats if github link found

  // Raw collection for debugging
  rawEvidence Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chatId])
  @@index([userId])
  @@index([analysisId])
}

model AutomationAsset {
  id               String         @id @default(cuid())
  automationPlan   AutomationPlan @relation(fields: [automationPlanId], references: [id], onDelete: Cascade)
  automationPlanId String

  assetType    String // email, linkedin_post, instagram_post, image_ad, video_ad, dm_template, lead_list
  assetTitle   String
  assetContent Json
  channel      String?
  status       String  @default("draft") // draft, needs_review, approved, scheduled, published_demo

  // Scheduling
  scheduledFor DateTime?
  publishedAt  DateTime?

  // Approval
  approvedBy  String?
  approvedAt  DateTime?
  rejectedBy  String?
  rejectedAt  DateTime?
  reviewNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([automationPlanId, status])
  @@index([automationPlanId, assetType])
}

model AutomationLog {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  chatId    String?
  assetId   String?
  action    String // generated, approved, scheduled, published_demo, edited, regenerated
  message   String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([chatId, action])
}

// ============================================
// EXECUTION RECORD (Phase 9 — Execution History)
// ============================================

model ExecutionRecord {
  id               String          @id @default(cuid())
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  chat             Chat            @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId           String
  automationPlan   AutomationPlan? @relation(fields: [automationPlanId], references: [id], onDelete: SetNull)
  automationPlanId String?

  module             String // email, poster, video, crm_workflow, campaign_plan, content, social
  contextSnapshotId  String? // ctx_<chatId>_<timestamp>
  provider           String? // gmail, sendgrid, pollinations, shotstack, etc.
  requestStatus      String // pending, running, success, failed, retrying
  providerResponseId String? // provider's tracking ID
  assetUrls          Json? // [{ type, url }]
  errorCategory      String? // auth_failed, timeout, provider_unavailable, invalid_request, unknown

  retryCount Int @default(0)
  maxRetries Int @default(3)

  requestPayload  Json? // what was sent
  responseSummary Json? // what came back (no secrets)

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, chatId, module])
  @@index([chatId, requestStatus])
  @@index([automationPlanId])
}

// ============================================
// EXECUTIVE SEO DASHBOARD
// ============================================

model ExecutiveSeoDashboard {
  id                String          @id @default(cuid())
  seoIntelligence   SeoIntelligence @relation(fields: [seoIntelligenceId], references: [id], onDelete: Cascade)
  seoIntelligenceId String          @unique

