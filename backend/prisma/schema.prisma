model CustomerHealthSnapshot {
  id        String      @id @default(cuid())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  chat      Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId    String
  contact   CRMContact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String?
  company   CRMCompany? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId String?
  deal      CRMDeal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId    String?

  healthStatus          String // HEALTHY, AT_RISK, CRITICAL, NOT_MEASURED
  riskFlags             Json? // [{ flag, reason, severity }]
  inactivityDays        Int?
  daysSinceLastActivity Int?
  daysSinceLastTask     Int?
  daysSinceLastMeeting  Int?
  openDealCount         Int     @default(0)
  overdueTaskCount      Int     @default(0)
  hasUpcomingRenewal    Boolean @default(false)
  missingOwner          Boolean @default(false)
  staleDeal             Boolean @default(false)

  calculatedAt DateTime @default(now())

  @@index([chatId, healthStatus])
  @@index([contactId])
  @@index([companyId])
  @@index([dealId])
  @@index([calculatedAt])
  @@index([userId])
}
