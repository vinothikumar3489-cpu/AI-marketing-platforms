generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                   @id @default(cuid())
  name                   String
  email                  String                   @unique
  password               String
  profileImage           String?
  role                   String?                  @default("member")
  lastActiveAt           DateTime?
  chats                  Chat[]
  analyses               Analysis[]
  seoAnalyses            SeoAnalysis[]
  productProfiles        ProductProfile[]
  productAnalyses        ProductAnalysis[]
  productIntelligence    ProductIntelligence[]
  competitorIntelligence CompetitorIntelligence[]
  campaignIntelligence   CampaignIntelligence[]
  seoIntelligence        SeoIntelligence[]
  agentRuns              AgentRun[]
  notifications          Notification[]
  automationPlans        AutomationPlan[]
  automationLogs         AutomationLog[]
  evidenceSnapshots      EvidenceSnapshot[]

  // Growth Execution Layer relations
  growthSprints GrowthSprint[]
  growthTasks   GrowthTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Chat {
  id                     String                  @id @default(cuid())
  user                   User                    @relation(fields: [userId], references: [id])
  userId                 String
  title                  String
  productName            String?
  messages               Message[]
  analysis               Analysis[]
  seoAnalysis            SeoAnalysis?
  productProfile         ProductProfile?
  productAnalysis        ProductAnalysis?
  productIntelligence    ProductIntelligence?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  competitorIntelligence CompetitorIntelligence?
  campaignIntelligence   CampaignIntelligence?

  seoIntelligence SeoIntelligence?
  AgentRun        AgentRun[]
  automationPlan  AutomationPlan?

  // Growth Execution Layer relations
  growthSprints GrowthSprint[]
  growthTasks   GrowthTask[]
  evidenceSnapshots EvidenceSnapshot[]

  @@index([userId])
}

model Message {
  id           String   @id @default(cuid())
  chat         Chat     @relation(fields: [chatId], references: [id])
  chatId       String
  role         String
  content      String
  analysisData Json?
  createdAt    DateTime @default(now())

  @@index([chatId])
}

model Analysis {
  id                  String   @id @default(cuid())
  chat                Chat     @relation(fields: [chatId], references: [id])
  chatId              String
  user                User     @relation(fields: [userId], references: [id])
  userId              String
  productName         String
  productDescription  String
  targetAudience      String
  marketInsights      Json?
  competitorInsights  Json?
  campaignSuggestions Json?
  roiSuggestions      Json?
  evidenceSnapshots   EvidenceSnapshot[]
  createdAt           DateTime @default(now())

  @@index([chatId])
  @@index([userId])
}

model SeoAnalysis {
  id                 String   @id @default(cuid())
  chat               Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId             String
  websiteUrl         String?
  seoScore           Int?
  visibilityScore    Int?
  organicTraffic     Int?
  backlinkCount      Int?
  keywordCount       Int?
  avgPosition        Float?
  ctr                Float?
  topKeywords        Json?
  competitorKeywords Json?
  backlinks          Json?
  trafficEstimate    Json?
  technicalIssues    Json?
  contentSuggestions Json?
  prediction         Json?
  source             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model ProductProfile {
  id             String   @id @default(cuid())
  chat           Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  productName    String
  companyName    String?
  websiteUrl     String?
  description    String?
  industry       String?
  targetAudience String?
  pricing        String?
  competitors    String?
  businessGoal   String?
  scrapedData    Json?
  mergedData     Json?
  scrapeStatus   String   @default("pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ProductAnalysis {
  id                  String   @id @default(cuid())
  chat                Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId              String
  productSummary      String?
  category            String?
  confidenceScore     Int?
  usp                 Json?
  features            Json?
  benefits            Json?
  painPoints          Json?
  targetUsers         Json?
  competitorTypes     Json?
  competitors         Json?
  directCompetitors   Json?
  indirectCompetitors Json?
  emergingCompetitors Json?
  businessModel       String?
  revenueModel        String?
  marketSegment       String?
  pricingPosition     String?
  marketMaturity      String?
  marketingAngles     Json?
  seoOpportunities    Json?
  campaignIdeas       Json?
  recommendedChannels Json?
  confidenceBreakdown Json?
  recommendedModules  Json?
  apiStatus           Json?
  buyerPersonas       Json?
  dataSourcesUsed     Json?
  providers           Json?
  aiWarnings          Json?
  warnings            Json?
  source              String?
  // Custom fields for our new flow
  provider            String?
  fallbackUsed        Boolean? @default(false)
  inputJson           Json?
  outputJson          Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model ProductIntelligence {
  id     String @id @default(cuid())
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  productAnalysis      Json?
  marketDiscovery      Json?
  audienceIntelligence Json?

  // Common fields for all modules
  provider     String?
  fallbackUsed Boolean? @default(false)
  inputJson    Json?
  status       String?  @default("pending")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompetitorIntelligence {
  id     String @id @default(cuid())
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  competitorAnalysis Json?
  intentPrediction   Json?
  positioningEngine  Json?

  // Custom fields for our new flow
  provider     String?
  fallbackUsed Boolean? @default(false)
  inputJson    Json?
  status       String?  @default("pending")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CampaignIntelligence {
  id     String @id @default(cuid())
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  campaignGenerator     Json?
  channelRecommendation Json?
  executiveStory        Json?
  actionPlan            Json?

  provider     String?
  fallbackUsed Boolean? @default(false)
  inputJson    Json?
  status       String?  @default("pending")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// GROWTH WORKSPACE EXECUTION MODELS
// ============================================

model GrowthSprint {
  id        String       @id @default(cuid())
  chat      Chat         @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  name      String // e.g., "Immediate", "Day 7", "This Month"
  startDate DateTime?
  endDate   DateTime?
  status    String       @default("active") // active, completed, planned
  tasks     GrowthTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chatId])
  @@index([userId])
}

model GrowthTask {
  id       String        @id @default(cuid())
  chat     Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId   String
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  sprint   GrowthSprint? @relation(fields: [sprintId], references: [id])
  sprintId String?

  title       String
  description String? @db.Text
  status      String  @default("todo") // todo, in_progress, in_review, done
  priority    String  @default("Medium") // High, Medium, Low, Critical
  difficulty  String? // Hard, Medium, Easy
  impact      String? // Business value / Impact description
  owner       String? @default("Marketing Team")
  kpi         String?

  estimatedTime String? // e.g., "3 hours", "2 days"
  targetKeyword String?
  affectedPage  String?

  // Progress tracking
  progress    Int       @default(0) // 0-100
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  dueDate     DateTime?

  // Generative AI Context
  aiGeneratedType String? // e.g., "meta_tags", "blog_post", "faq"
  aiPromptContext Json? // Stores the context needed to run inline generation

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chatId])
  @@index([userId])
  @@index([sprintId])
}

model SeoIntelligence {
  id     String @id @default(cuid())
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  websiteUrl             String?
  domain                 String?
  companyName            String?
  productName            String?
  analyzedAt             DateTime? @default(now())
  seoScore               Int?
  technicalAudit         Json?
  keywordOpportunities   Json?
  competitorKeywords     Json?
  contentGaps            Json?
  aiVisibility           Json?
  landingPageSuggestions Json?
  blogIdeas              Json?
  actionPlan             Json?

  // Metadata
  providers    Json?
  warnings     Json?
  status       String?  @default("pending")
  fallbackUsed Boolean? @default(false)
  inputJson    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // New Relations for Enhanced SEO + GEO
  rawCrawlData           RawCrawlData[]
  technicalAuditDetail   TechnicalSeoAudit?
  scoreBreakdown         SeoScoreBreakdown?
  keywordIntelligence    KeywordIntelligenceRecord?
  topicClusters          TopicCluster[]
  seoCompetitors         SeoCompetitorIntelligence[]
  geoIntelligence        GeoIntelligenceRecord?
  competitorSeoRecord    CompetitorSeoRecord?
  contentGapDetails      ContentGap[]
  blogIntelligenceItems  BlogIntelligence[]
  contentGapRecord       ContentGapRecord?
  blogIntelligenceRecord BlogIntelligenceRecord?
  executiveDashboard     ExecutiveSeoDashboard?
}

// ============================================
// RAW CRAWL DATA
// ============================================

model RawCrawlData {
  id                String          @id @default(cuid())
  seoIntelligence   SeoIntelligence @relation(fields: [seoIntelligenceId], references: [id], onDelete: Cascade)
  seoIntelligenceId String

  url        String
  html       String   @db.Text
  text       String   @db.Text
  metadata   Json
  technical  Json
  content    Json
  structured Json
  provider   String
  scrapedAt  DateTime @default(now())

  @@index([seoIntelligenceId])
}

// ============================================
// TECHNICAL SEO AUDIT (DETAILED)
// ============================================

model TechnicalSeoAudit {
  id                String          @id @default(cuid())
  seoIntelligence   SeoIntelligence @relation(fields: [seoIntelligenceId], references: [id], onDelete: Cascade)
  seoIntelligenceId String          @unique

  // Full audit data structure
  auditData Json

  // Individual scores for quick access
  overallScore  Int
  titleScore    Int
  metaScore     Int
  securityScore Int
  mobileScore   Int
  headingScore  Int
  schemaScore   Int

  // Issues by priority
  criticalIssues Json
  highIssues     Json
  mediumIssues   Json
  lowIssues      Json

  // Recommendations
  recommendations Json

  analyzedAt DateTime @default(now())
}

// ============================================
// SEO SCORE BREAKDOWN
// ============================================

model SeoScoreBreakdown {
  id                String          @id @default(cuid())
  seoIntelligence   SeoIntelligence @relation(fields: [seoIntelligenceId], references: [id], onDelete: Cascade)
  seoIntelligenceId String          @unique

  // Dimensional scores
  technicalScore    Int
  onPageScore       Int
  contentScore      Int
  authorityScore    Int
  aiVisibilityScore Int
  localSeoScore     Int
  overallScore      Int

  // Score history for trend tracking
  scoreHistory Json?

  lastCalculated DateTime @default(now())
}

// ============================================
// KEYWORD INTELLIGENCE (Consolidated Model)
// ============================================

model KeywordIntelligenceRecord {
  id                String          @id @default(cuid())
  seoIntelligence   SeoIntelligence @relation(fields: [seoIntelligenceId], references: [id], onDelete: Cascade)
  seoIntelligenceId String          @unique

  // Keyword Categories (JSON arrays of keyword objects)
  primaryKeywords   Json // [{ keyword, intent, difficulty, opportunity, confidenceScore, reason }]
  secondaryKeywords Json // [{ keyword, intent, difficulty, opportunity, confidenceScore, reason }]
  longTailKeywords  Json // [{ keyword, intent, difficulty, opportunity, confidenceScore, reason }]
  questionKeywords  Json // [{ keyword, intent, difficulty, opportunity, confidenceScore, reason }]

  // Topic Clusters
  clusters Json // [{ name, keywords[], priority, contentSuggestions[] }]

  // Competitor Keywords
  competitorKeywords Json // [{ keyword, competitorUsing, reason, opportunity, intent, difficulty }]

  // Content Opportunities
  contentOpportunities Json // [{ keyword, pageSuggestion, reason, impact, type, priority }]

  // GEO Keywords (AI Search Optimization)
  geoKeywords Json // [{ question, platform, answerOpportunity, contentSuggestion, intent }]

  // Metadata
  totalKeywords      Int @default(0)
  clustersCount      Int @default(0)
  opportunitiesCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([seoIntelligenceId])
}

// ============================================
// TOPIC CLUSTERS
// ============================================

model TopicCluster {
  id                String          @id @default(cuid())
  seoIntelligence   SeoIntelligence @relation(fields: [seoIntelligenceId], references: [id], onDelete: Cascade)
  seoIntelligenceId String

  name               String
  keywords           Json // array of keyword IDs or strings
  priority           Int
  contentSuggestions Json

  createdAt DateTime @default(now())

  @@index([seoIntelligenceId, priority])
}

// ============================================
// SEO COMPETITOR INTELLIGENCE
// ============================================

model SeoCompetitorIntelligence {
  id                String          @id @default(cuid())
  seoIntelligence   SeoIntelligence @relation(fields: [seoIntelligenceId], references: [id], onDelete: Cascade)
  seoIntelligenceId String

  name    String
  website String
  type    String // direct, indirect
  reason  String @db.Text

  // Analysis
  strengths       Json
  weaknesses      Json
  contentStrategy String? @db.Text
  positioning     String? @db.Text
  seoAdvantages   Json

  // Gaps
  keywordGaps   Json
  contentGaps   Json
  authorityGaps Json

  authorityEstimate Int?
  createdAt         DateTime @default(now())

  @@index([seoIntelligenceId, type])
}

// ============================================
// GEO INTELLIGENCE (Generative Engine Optimization)
// ============================================

model GeoIntelligenceRecord {
  id                String          @id @default(cuid())
  seoIntelligence   SeoIntelligence @relation(fields: [seoIntelligenceId], references: [id], onDelete: Cascade)
  seoIntelligenceId String          @unique

  // Overall AI Visibility Score
  aiVisibilityScore Int

  // Individual Platform Scores
  chatGptScore          Int
  geminiScore           Int
  claudeScore           Int
  perplexityScore       Int
  googleAiOverviewScore Int

  // Component Scores
  entityCoverageScore          Int
  knowledgeGraphReadinessScore Int
  citationReadinessScore       Int
  answerabilityScore           Int
  topicalAuthorityScore        Int

  // Detailed Analysis Data (JSON)
  entities               Json // [{ entity, type, confidenceScore, context }]
  knowledgeGraphEntities Json // [{ type, status }]
  citationOpportunities  Json // [{ type, opportunity, impact, reason }]
  faqOpportunities       Json // [{ question, reason, impact, recommendation }]
  aiContentOpportunities Json // [{ type, opportunity, reason, impact, difficulty, priority }]
  trustSignals           Json // { score, signals, recommendations }
  recommendations        Json // { immediate, day30, day90 }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([seoIntelligenceId])
}

// ============================================
// CONTENT GAPS
// ============================================

model ContentGap {
  id                String          @id @default(cuid())
  seoIntelligence   SeoIntelligence @relation(fields: [seoIntelligenceId], references: [id], onDelete: Cascade)
  seoIntelligenceId String

  type             String // missing-topic, missing-page, missing-blog, missing-use-case, missing-faq
  title            String
  reason           String  @db.Text
  opportunityScore Int
  priority         String // critical, high, medium, low
  competitors      Json // which competitors have this
  suggestedPage    String? @db.Text

  createdAt DateTime @default(now())

  @@index([seoIntelligenceId, opportunityScore])
}

// ============================================
// BLOG INTELLIGENCE
// ============================================

model BlogIntelligence {
  id                String          @id @default(cuid())
  seoIntelligence   SeoIntelligence @relation(fields: [seoIntelligenceId], references: [id], onDelete: Cascade)
  seoIntelligenceId String

  title           String
  keyword         String
  intent          String
  difficulty      String
  opportunity     String
  estimatedImpact String
  outline         Json?
  metaDescription String? @db.Text

  createdAt DateTime @default(now())

  @@index([seoIntelligenceId, opportunity])
}

// ============================================
// CONTENT GAP INTELLIGENCE (Consolidated Record)
// ============================================

model ContentGapRecord {
  id                String          @id @default(cuid())
  seoIntelligence   SeoIntelligence @relation(fields: [seoIntelligenceId], references: [id], onDelete: Cascade)
  seoIntelligenceId String          @unique

  // Missing Content & Pages
  contentGaps Json // [{ title, contentType, priority, opportunityScore, competitorExample, reason, suggestedAction, estimatedImpact }]

  // Landing Page Opportunities
  landingPageIdeas Json // [{ pageTitle, targetKeyword, intent, headline, subHeadline, keySections, CTA, trustElements, recommendedSchema, opportunityScore, priority }]

  // Comparison Page Opportunities
  comparisonPageIdeas Json // [{ title, targetKeyword, comparisonPoints, whyCreate, rankingPotential, opportunityScore, priority, estimatedImpact }]

  // FAQ Opportunities
  faqOpportunities Json // [{ question, answerIntent, targetAudience, geoPotential, seoPotential, reason, recommendedAnswer, priority }]

  // GEO Content Ideas (AI-Optimized)
  geoContentIdeas Json // [{ title, contentType, aiVisibilityImpact, citationPotential, answerabilityPotential, targetPlatforms, keySections, priority, estimatedImpact }]

  // Resource Page Ideas
  resourcePageIdeas Json // [{ title, contentType, targetKeyword, opportunityScore, priority, sections }]

  // Content Calendar (30/60/90 days)
  contentCalendar Json // { day30: [...], day60: [...], day90: [...] }

  // Summary Metrics
  summary Json // { totalGaps, totalOpportunities, criticalPriority, highPriority }

  // Metadata
  metadata Json? // { analyzedAt, analysisVersion }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([seoIntelligenceId])
}

// ============================================
// BLOG INTELLIGENCE (Consolidated Record)
// ============================================

model BlogIntelligenceRecord {
  id                String          @id @default(cuid())
  seoIntelligence   SeoIntelligence @relation(fields: [seoIntelligenceId], references: [id], onDelete: Cascade)
  seoIntelligenceId String          @unique

  // Blog Ideas (50+ ideas)
  blogIdeas Json // [{ title, targetKeyword, searchIntent, difficulty, opportunity, contentType, estimatedImpact, priority, reason }]

  // Blog Clusters
  blogClusters Json // [{ clusterName, authorityScore, blogIdeas, targetAudience, publishingFrequency }]

  // Blog Briefs (SEO Briefs for top ideas)
  blogBriefs Json // [{ title, primaryKeyword, secondaryKeywords, targetAudience, searchIntent, contentOutline, faqSuggestions, schemaSuggestions, internalLinkSuggestions, wordCountTarget, estimatedReadTime, priority }]

  // Publishing Calendar
  publishingCalendar Json // { week1: [...], week2: [...], week3: [...], week4: [...], month2: [...], month3: [...] }

  // Summary Metrics
  summary Json // { totalIdeas, totalClusters, highPriorityIdeas }

  // Metadata
  metadata Json? // { analyzedAt, analysisVersion }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([seoIntelligenceId])
}

// ============================================
// COMPETITOR SEO INTELLIGENCE
// ============================================

model CompetitorSeoRecord {
  id                String          @id @default(cuid())
  seoIntelligence   SeoIntelligence @relation(fields: [seoIntelligenceId], references: [id], onDelete: Cascade)
  seoIntelligenceId String          @unique

  // Discovered Competitors
  competitors Json // [{ name, website, description, competitorType, reason, confidenceScore, sources }]

  // Competitor Profiles
  competitorProfiles Json // [{ name, domain, website, mainKeywords, contentThemes, positioning, strengths, weaknesses, estimatedAuthority, aiVisibilityEstimate }]

  // Keyword Gaps
  keywordGaps Json // { missingKeywords, sharedKeywords, competitorOnlyKeywords, highOpportunityKeywords, lowCompetitionKeywords, summary }

  // Content Gaps
  contentGaps Json // [{ gapType, title, reason, competitorExample, opportunityScore, priority, suggestedAction }]

  // Authority Gaps
  authorityGaps Json // { authorityGapScore, userStrengths, competitorAdvantages, backlinkOpportunities, citationOpportunities, trustSignalGaps }

  // GEO Gaps
  geoGaps Json // { entityCoverageGap, citationReadinessGap, answerabilityGap, topicalAuthorityGap, aiVisibilityGap, recommendedFixes }

  // Competitor Matrix
  competitorMatrix Json // [{ name, website, keywordStrength, contentStrength, authorityStrength, geoStrength, overallThreatScore, weaknessToExploit, recommendedStrategy }]

  // Recommendations
  recommendations Json // { immediate, day30, day90, competitivePriorities }

  // Metadata
  metadata Json? // { totalCompetitors, directCompetitors, analyzedAt }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([seoIntelligenceId])
}

model AgentRun {
  id     String @id @default(cuid())
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  agentType String
  status    String
  input     Json?
  output    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chatId])
  @@index([userId])
}

// ============================================
// AUTOMATION MODELS
// ============================================

model AutomationPlan {
  id     String @id @default(cuid())
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId String @unique

  // Campaign Details
  campaignName      String
  campaignObjective String?
  targetAudience    Json?
  channels          Json? // array of channel objects
  weeklyPlan        Json?
  kpis              Json?
  budgetSplit       Json?

  // Email Automation
  emailSequence Json?
  emailSubjects Json?
  emailSchedule Json?
  leadCriteria  Json?

  // LinkedIn Automation
  linkedInCalendar    Json?
  linkedInPosts       Json?
  linkedInDmTemplates Json?
  linkedInSchedule    Json?

  // Instagram Automation
  instagramCaptions  Json?
  instagramReelIdeas Json?
  instagramSchedule  Json?
  instagramHashtags  Json?

  // Creative Generation
  posterPrompts Json?
  imageAdIdeas  Json?
  designStyles  Json?

  // Video Ad Generation
  videoScripts  Json?
  videoScenes   Json?
  videoSchedule Json?

  // Campaign Generation
  googleAds       Json?
  contentCalendar Json?
  crmWorkflows    Json?
  workflows       Json?

  // Lead Generation
  idealLeadProfile Json?
  leadSources      Json?
  outreachAngles   Json?
  sampleLeads      Json?

  // Phase 6 — Marketing Execution Platform
  contentStudio      Json? // Blog articles, landing pages, case studies, etc.
  emailCampaigns     Json? // Email campaign drafts with compliance checklists
  creativeStudio     Json? // Creative briefs for posters, banners, carousels, etc.
  videoStudio        Json? // Video scripts with storyboards
  campaignPlans      Json? // 30/60/90 day campaign plans
  socialCalendars    Json? // Social media content calendars
  analyticsData      Json? // Execution analytics and metrics tracking

  // Automation Assets
  assets AutomationAsset[]

  // Metadata
  readinessScore Int?     @default(0)
  status         String   @default("draft") // draft, approved, scheduled, running, paused, completed
  provider       String?
  fallbackUsed   Boolean? @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// EVIDENCE SNAPSHOT (Phase 1 — Evidence Engine)
// ============================================

model EvidenceSnapshot {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId    String
  analysis  Analysis? @relation(fields: [analysisId], references: [id], onDelete: SetNull)
  analysisId String?

  websiteUrl    String
  companyName   String?
  sourceSummary Json? // { sourcesCollected: [...], missingSources: [...] }

  // Evidence collections (all nullable — never fake)
  websiteEvidence      Json? // title, meta, headings, hero, CTA, features, page detection
  technicalSeoEvidence Json? // pagespeed scores, robots, sitemap
  contentEvidence      Json? // opengraph, schema, technology detection
  competitorEvidence   Json? // reserved for later
  githubEvidence       Json? // repo stats if github link found

  // Raw collection for debugging
  rawEvidence Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([chatId])
  @@index([userId])
  @@index([analysisId])
}

model AutomationAsset {
  id               String         @id @default(cuid())
  automationPlan   AutomationPlan @relation(fields: [automationPlanId], references: [id], onDelete: Cascade)
  automationPlanId String

  assetType    String // email, linkedin_post, instagram_post, image_ad, video_ad, dm_template, lead_list
  assetTitle   String
  assetContent Json
  channel      String?
  status       String  @default("draft") // draft, needs_review, approved, scheduled, published_demo

  // Scheduling
  scheduledFor DateTime?
  publishedAt  DateTime?

  // Approval
  approvedBy  String?
  approvedAt  DateTime?
  rejectedBy  String?
  rejectedAt  DateTime?
  reviewNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([automationPlanId, status])
  @@index([automationPlanId, assetType])
}

model AutomationLog {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  chatId    String?
  assetId   String?
  action    String // generated, approved, scheduled, published_demo, edited, regenerated
  message   String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([chatId, action])
}

// ============================================
// EXECUTIVE SEO DASHBOARD
// ============================================

model ExecutiveSeoDashboard {
  id                String          @id @default(cuid())
  seoIntelligence   SeoIntelligence @relation(fields: [seoIntelligenceId], references: [id], onDelete: Cascade)
  seoIntelligenceId String          @unique

  // Executive Overview
  executiveOverview Json // { overallSeoScore, overallGeoScore, keywordOpportunityScore, competitivePositionScore, contentReadinessScore, growthOpportunityScore }

  // SEO Health Summary
  seoHealthSummary Json // { categories, strengths, weaknesses, topIssues }

  // Key Opportunities
  keyOpportunities Json // [{ title, impact, effort, priority, recommendation, category }]

  // Competitor Snapshot
  competitorSnapshot Json // { topCompetitors, recommendations, summary }

  // AI Search Visibility
  aiSearchVisibility Json // { platformScores, componentScores, overallAiVisibility, recommendations }

  // Content Strategy Summary
  contentStrategySummary Json // { missingPages, blogOpportunities, faqOpportunities, highPriorityContent, contentCalendarSummary }

  // Executive Action Plan
  executiveActionPlan Json // { immediateActions, day30Plan, day60Plan, day90Plan, summary }

  // ROI Forecast
  roiForecast Json // { trafficGrowthPotential, keywordGrowthPotential, aiVisibilityGrowthPotential, contentImpact, competitiveGains, summary }

  // Metadata
  metadata Json? // { generatedAt, dataCompleteness }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([seoIntelligenceId])
}
