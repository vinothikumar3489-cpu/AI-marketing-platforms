  fleetSizeEstimate       Json? // { estimate, evidence, inferenceStatus }
  decisionMakerConfidence Json? // { confidence, evidence, inferenceStatus }
  timelinePrediction      Json? // { predictedCloseDate, probability, inferenceStatus }

